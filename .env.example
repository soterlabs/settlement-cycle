# Copy to `.env` and fill in your own keys. `.env` is gitignored.
#
# Loaded automatically at `import settle` time (via python-dotenv).
# A real environment variable in the shell still wins — `.env` is just a
# convenience for local runs.

# Per-chain RPC endpoints. Names match `RPC_ENV_VARS` in extract/rpc.py;
# adding a new chain requires updating that mapping AND the Chain enum in
# domain/primes.py.
ETH_RPC=https://eth-mainnet.g.alchemy.com/v2/<your_key>
BASE_RPC=https://base-mainnet.g.alchemy.com/v2/<your_key>
AVALANCHE_C_RPC=https://avax-mainnet.g.alchemy.com/v2/<your_key>
MONAD_RPC=https://monad-mainnet.g.alchemy.com/v2/<your_key>
PLUME_RPC=https://rpc.plumenetwork.xyz

# Dune API key for live (non-fixture) Dune source paths.
DUNE_API_KEY=
